rules_version = '2';

// Cada usuário autenticado é dono direto dos próprios dados — sem
// workspace/tenant compartilhado. `uid` é um segmento fixo do caminho
// comparado com request.auth.uid, então o Firestore consegue provar a
// regra estaticamente para queries de listagem (get()/resource.data não
// são necessários aqui, evitando as armadilhas de permission-denied em
// list queries).
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
